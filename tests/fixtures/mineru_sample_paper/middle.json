              "spans": [
                {
                  "bbox": [72, 200, 540, 260],
                  "type": "text",
                  "content": "We present AdaptRAG, a novel framework for retrieval-augmented generation that dynamically adjusts retrieval granularity based on query complexity. Our approach demonstrates significant improvements over baseline systems on multiple benchmarks, achieving state-of-the-art performance while reducing computational overhead.",
                  "score": 0.98
                }
              ]
            }
          ]
        },
        {
          "type": "title",
          "bbox": [72, 310, 230, 330],
          "angle": 0,
