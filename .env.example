# Paper Notebook Agent — example env (NO real secrets)

# --- MinerU hybrid client ---
# OpenAI-compatible VLM server URL used by `mineru -b hybrid-http-client -u ...`
# Default assumes vLLM running locally: `vllm serve opendatalab/MinerU2.5-2509-1.2B --port 8001`.
MINERU_SERVER_URL=http://localhost:8001

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/paper_notebook

# --- Vespa ---
VESPA_ENDPOINT=http://localhost:8089
# Set to false to skip Vespa indexing/retrieval entirely (CI / early dev)
VESPA_ENABLED=true

# --- Application secrets (rotate in deployment) ---
APP_ENCRYPTION_KEY=change-me-32-bytes-base64

# --- Provider keys (leave blank in dev; real keys live only in real .env) ---
# These are used as fallback env-level defaults only.
# Per-chat provider config is stored encrypted in the provider_profiles table.
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Env-level default LLM (used when a chat has no default_chat_profile) ---
# Lets you point the QA agent at a real LLM without inserting a DB row.
# LLM_PROVIDER: "mock" (default) | "openai_compatible" | "openai" | "gemini_native"
# LLM_API_URL: base URL of an OpenAI-compatible server. A trailing
#   "/chat/completions" is stripped automatically because the OpenAI SDK
#   appends that path itself, so either form works.
#   Examples:
#     http://localhost:8001/v1
#     http://example.com:8599/v1/chat/completions   (same thing)
LLM_PROVIDER=mock
LLM_API_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=60
# Total input budget (system + history + plan + evidence + answer reserve).
# Increase if your documents are long and summaries get truncated.
# Frontend may override per request.
LLM_CONTEXT_WINDOW=10000

# --- Runtime wiring notes ---
# Chat provider resolution order (messages API):
#   1. Chat.default_chat_profile_id  (DB-stored, encrypted key)  ← production
#   2. LLM_* env vars above (built into OpenAICompatChatProvider) ← dev/demo
#   3. ExtractiveEvidenceChatProvider (retrieved evidence only)   ← unconfigured
#
# Vespa retrieval is enabled when VESPA_ENABLED=true. Query/document embeddings
# and native rerank use Vespa's bundled e5 embedder; no per-user embedding or
# reranker profile is required.
EMBEDDING_DIM=384

# --- Vision LLM (figure / table narration during ingestion) ---
# Used at ingestion time only — every figure / table block is sent to the VLM
# together with its same-page text, and the response (HTML for tables, two
# natural-language paragraphs for figures) becomes its own Vespa chunk that is
# embedded next to the page text.
#
# VLM_PROVIDER: "openai_compatible" (default; matches self-hosted Gemma-4 vLLM)
#               | "openai" | "gemini_native"
# VLM_API_URL : base URL of the OpenAI-compatible server. Either
#               ``http://host:port/v1`` or ``http://host:port/v1/chat/completions``
#               is accepted (the client normalises the path).
# VLM_MODEL   : model identifier sent in the request payload.
# VLM_API_KEY : "not-needed" for self-hosted vLLM; a real key for OpenAI / Gemini.
VLM_PROVIDER=openai_compatible
VLM_API_URL=http://116.50.36.82:8599/v1/chat/completions
VLM_MODEL=gemma-4-31B-it
VLM_API_KEY=not-needed
VLM_MAX_TOKENS=2048
VLM_TEMPERATURE=0.0
VLM_TIMEOUT=180
VLM_IMAGE_MAX_SIDE=1024
VLM_IMAGE_JPEG_QUALITY=90
VLM_ENABLED=true
